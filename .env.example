# GitHub Image Host 环境变量配置
# 复制此文件为 .env 并填写实际值

# GitHub API 配置
# 获取方式: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# 权限要求: repo（完整仓库访问权限）
GITHUB_TOKEN=your_github_personal_access_token

# Webhook 签名验证密钥
# 生成方式: openssl rand -base64 32
# 请与 GitHub 仓库 Webhook 设置中的 Secret 保持一致
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# 服务器端口（可选，默认 3000）
PORT=3000

# 日志级别（可选: debug | info | warn | error，默认 info）
LOG_LEVEL=info
